<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

  <sys:String x:Key="LOCUpcomingGamesTaggerMenuUpdateTag">Tag für kommende Spiele aktualisieren</sys:String>
  <sys:String x:Key="LOCUpcomingGamesTaggerMenuSection">Upcoming Games Tagger</sys:String>

  <sys:String x:Key="LOCUpcomingGamesTaggerNotifTagCreated">Tag '{0}' für kommende Spiele erstellt</sys:String>
  <sys:String x:Key="LOCUpcomingGamesTaggerNotifTagUpdated">Tag '{0}' aktualisiert: +{1} Spiele, -{2} Spiele</sys:String>

  <sys:String x:Key="LOCUpcomingGamesTaggerSettingsTagSettings">Tag-Einstellungen</sys:String>
  <sys:String x:Key="LOCUpcomingGamesTaggerSettingsTagName">Tag-Name:</sys:String>
  <sys:String x:Key="LOCUpcomingGamesTaggerSettingsAutoUpdate">Tag automatisch aktualisieren, wenn sich die Bibliothek ändert</sys:String>
  <sys:String x:Key="LOCUpcomingGamesTaggerSettingsShowNotifications">Benachrichtigungen anzeigen, wenn der Tag aktualisiert wird</sys:String>
  <sys:String x:Key="LOCUpcomingGamesTaggerSettingsGameSelection">Spielauswahl</sys:String>
  <sys:String x:Key="LOCUpcomingGamesTaggerSettingsIncludeNoDate">Spiele ohne Erscheinungsdatum einbeziehen</sys:String>
  <sys:String x:Key="LOCUpcomingGamesTaggerSettingsDaysThreshold">Schwellenwert in Tagen (0 = kein Limit):</sys:String>
  <sys:String x:Key="LOCUpcomingGamesTaggerSettingsDaysThresholdHint">Nur Spiele einbeziehen, die innerhalb dieser Anzahl von Tagen erscheinen</sys:String>

</ResourceDictionary>
